{
  "id": "judicial-watcher",
  "name": "Monitor Judicial",
  "version": "1.0.0",
  "status": "stable",
  "maintainer": "adriano@traderisk.com.br",
  "linkedSkills": ["judicial-monitoring"],
  "platforms": {
    "claude-code": {
      "kind": "subagent",
      "path": "~/.claude/agents/judicial-watcher.md",
      "notes": "Markdown com frontmatter name/description/tools/model."
    },
    "openai": {
      "kind": "assistant-or-custom-gpt",
      "notes": "Usar AGENT.md (sem frontmatter) como Instructions; tools viram Functions."
    },
    "gemini": {
      "kind": "system-instruction",
      "notes": "Corpo do AGENT.md como system instruction; ferramentas via function calling."
    },
    "cursor": {
      "kind": "rules-or-mode",
      "notes": "Converter para .cursor/rules/judicial-watcher.mdc."
    },
    "manus": {
      "kind": "agent-config",
      "notes": "Corpo sem frontmatter no campo de instruções do agente."
    }
  }
}
